# 文档智能分析系统 — 环境变量配置
# 复制此文件为 .env 并填入实际值

# [必需] DashScope API Key (从 https://dashscope.console.aliyun.com/ 获取)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# [可选] API 认证 Token — 设置后，上传/删除接口需要 Bearer Token
# 不设置则所有接口开放访问（适合本地单用户使用）
API_TOKEN=

# [可选] 启用 Flask Debug 模式（切勿在生产环境使用）
FLASK_DEBUG=false
